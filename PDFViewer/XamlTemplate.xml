<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" RequestedTheme="Default">

<Page.Resources>
	<XamlUICommand x:Key="MenuCommandKey" x:Name="MenuCommand"/> <!-- This Xaml Command is bound to each menu item below -->
	<!-- Color brushes for swatches — referenced by Tag on each menu item -->
	<SolidColorBrush x:Key="BgWhite"			Color="White"/>
	<SolidColorBrush x:Key="BgAliceBlue"		Color="AliceBlue"/>
	<SolidColorBrush x:Key="BgAquamarine"		Color="Aquamarine"/>
	<SolidColorBrush x:Key="BgCornSilk"			Color="CornSilk"/>
	<SolidColorBrush x:Key="BgGainsboro"		Color="Gainsboro"/>
	<SolidColorBrush x:Key="BgLavender"			Color="Lavender"/>
	<SolidColorBrush x:Key="BgLightCyan"		Color="LightCyan"/>
	<SolidColorBrush x:Key="BgLightGreen"		Color="LightGreen"/>
	<SolidColorBrush x:Key="BgMistyRose"		Color="MistyRose"/>
	<SolidColorBrush x:Key="BgPaleTurquoise"	Color="PaleTurquoise"/>
	<SolidColorBrush x:Key="BgPeachPuff"		Color="PeachPuff"/>
	<SolidColorBrush x:Key="BgThistle"			Color="Thistle"/>
	<!-- ControlTemplate for MenuFlyoutItem with a color swatch -->
	<!-- The swatch Rectangle.Fill is bound to the item's Tag property which holds a SolidColorBrush resource -->
	<Style x:Key="ColorSwatchMenuItemStyle" TargetType="MenuFlyoutItem">
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="MenuFlyoutItem">
					<Grid x:Name="LayoutRoot" Padding="12,0,12,0" MinHeight="36" Background="{TemplateBinding Background}">

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal"/>
								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource MenuFlyoutItemBackgroundPointerOver}"/>
										<Setter Target="Label.Foreground" Value="{ThemeResource MenuFlyoutItemForegroundPointerOver}"/>
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource MenuFlyoutItemBackgroundPressed}"/>
										<Setter Target="Label.Foreground" Value="{ThemeResource MenuFlyoutItemForegroundPressed}"/>
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="Label.Foreground" Value="{ThemeResource MenuFlyoutItemForegroundDisabled}"/>
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">

							<!-- Color swatch — Fill bound to Tag holding a SolidColorBrush -->
							<Border Width="32" Height="16" VerticalAlignment="Center" BorderBrush="{ThemeResource MenuFlyoutItemForegroundDisabled}" BorderThickness="1" CornerRadius="2">
								<Rectangle Fill="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
							</Border>

							<TextBlock x:Name="Label" Text="{TemplateBinding Text}" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
						</StackPanel>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
</Page.Resources>

<Grid>
	<Grid.RowDefinitions>
		<RowDefinition Height="Auto"/>	<!-- MenuBar -->
		<RowDefinition Height="*"/>		<!-- ListView -->
	</Grid.RowDefinitions>

	<MenuBar Grid.Row="0" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"> <!-- ApplicationPageBackgroundThemeBrush -->

		<MenuBarItem x:Name="FileMenu" Title="File">

			<MenuFlyoutItem x:Name="OpenFile" Text="Open PDF file..." Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}">
				<MenuFlyoutItem.Icon><SymbolIcon Symbol="OpenFile"/></MenuFlyoutItem.Icon>
				<MenuFlyoutItem.KeyboardAccelerators><KeyboardAccelerator Key="O" Modifiers="Control"/></MenuFlyoutItem.KeyboardAccelerators>
			</MenuFlyoutItem>

			<MenuFlyoutSeparator/>

			<MenuFlyoutItem x:Name="Quit" Text="Quit" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}">
				<MenuFlyoutItem.Icon><SymbolIcon Symbol="Cancel"/></MenuFlyoutItem.Icon>
				<MenuFlyoutItem.KeyboardAccelerators><KeyboardAccelerator Key="Q" Modifiers="Control"/></MenuFlyoutItem.KeyboardAccelerators>
			</MenuFlyoutItem>

		</MenuBarItem>

		<MenuBarItem x:Name="RotationMenu" Title="Rotation">

			<ToggleMenuFlyoutItem x:Name="RotationNone" Text="No Rotation" Tag="0" IsChecked="True" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

			<ToggleMenuFlyoutItem x:Name="Rotation90" Text="Rotate 90&#176;" Tag="1" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

			<ToggleMenuFlyoutItem x:Name="Rotation180" Text="Rotate 180&#176;" Tag="2" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

			<ToggleMenuFlyoutItem x:Name="Rotation270" Text="Rotate 270&#176;" Tag="3" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

		</MenuBarItem>

		<MenuBarItem x:Name="BackgroundMenu" Title="Background">

			<MenuFlyoutItem Text="White" Tag="{StaticResource BgWhite}" Style="{StaticResource ColorSwatchMenuItemStyle}" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

			<MenuFlyoutSeparator/>

			<MenuFlyoutItem Text="AliceBlue" Tag="{StaticResource BgAliceBlue}" Style="{StaticResource ColorSwatchMenuItemStyle}" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

			<MenuFlyoutSeparator/>
			
			<MenuFlyoutItem Text="Aquamarine" Tag="{StaticResource BgAquamarine}" Style="{StaticResource ColorSwatchMenuItemStyle}" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
			
			<MenuFlyoutSeparator/>

			<MenuFlyoutItem Text="CornSilk" Tag="{StaticResource BgCornSilk}" Style="{StaticResource ColorSwatchMenuItemStyle}" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

			<MenuFlyoutSeparator/>

			<MenuFlyoutItem Text="Gainsboro" Tag="{StaticResource BgGainsboro}" Style="{StaticResource ColorSwatchMenuItemStyle}" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

			<MenuFlyoutSeparator/>

			<MenuFlyoutItem Text="Lavender" Tag="{StaticResource BgLavender}" Style="{StaticResource ColorSwatchMenuItemStyle}" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

			<MenuFlyoutSeparator/>

			<MenuFlyoutItem Text="LightCyan" Tag="{StaticResource BgLightCyan}" Style="{StaticResource ColorSwatchMenuItemStyle}" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

			<MenuFlyoutSeparator/>

			<MenuFlyoutItem Text="LightGreen" Tag="{StaticResource BgLightGreen}" Style="{StaticResource ColorSwatchMenuItemStyle}" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

			<MenuFlyoutSeparator/>

			<MenuFlyoutItem Text="MistyRose" Tag="{StaticResource BgMistyRose}" Style="{StaticResource ColorSwatchMenuItemStyle}" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

			<MenuFlyoutSeparator/>

			<MenuFlyoutItem Text="PaleTurquoise" Tag="{StaticResource BgPaleTurquoise}" Style="{StaticResource ColorSwatchMenuItemStyle}" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

			<MenuFlyoutSeparator/>

			<MenuFlyoutItem Text="PeachPuff" Tag="{StaticResource BgPeachPuff}" Style="{StaticResource ColorSwatchMenuItemStyle}" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

			<MenuFlyoutSeparator/>

			<MenuFlyoutItem Text="Thistle" Tag="{StaticResource BgThistle}" Style="{StaticResource ColorSwatchMenuItemStyle}" Command="{StaticResource MenuCommandKey}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

		</MenuBarItem>

	</MenuBar>

	<ListView x:Name="PdfListView" Grid.Row="1" SelectionMode="None" IsItemClickEnabled="False" ShowsScrollingPlaceholders="True" ToolTipService.ToolTip="Ctrl+MouseWheel to Zoom In/Out" ScrollViewer.ZoomMode="Enabled" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollMode="Enabled">
		<ListView.ItemContainerStyle>
			<Style TargetType="ListViewItem">
				<Setter Property="Padding" Value="0"/>
				<Setter Property="Margin" Value="0,0,0,8"/>
			</Style>
		</ListView.ItemContainerStyle>
		<ListView.ItemTemplate>
			<DataTemplate>
				<Border BorderThickness="1">
					<Image x:Name="PageImage" Stretch="Uniform" Source="{Binding}"/>
				</Border>
			</DataTemplate>
		</ListView.ItemTemplate>
	</ListView>
</Grid>

</Page>