<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" RequestedTheme="Default">
<Page.Resources>
    <Storyboard x:Name="FadeAnimation">
        <DoubleAnimation Storyboard.TargetName="AnimatedTextBlock" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:2" AutoReverse="True" RepeatBehavior="Forever">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseInOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetName="AnimatedTextBlock" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1" To="1.5" Duration="0:0:2" AutoReverse="True" RepeatBehavior="Forever">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseInOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetName="AnimatedTextBlock" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1" To="1.5" Duration="0:0:2" AutoReverse="True" RepeatBehavior="Forever">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseInOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>
</Page.Resources>

<Grid x:Name="MainGrid" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" Width="1280" Height="720">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <TextBlock x:Name="AnimatedTextBlock" Grid.Row="0" Text="Northwind Traders &#x2728;" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
        <TextBlock.Foreground>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="Red" Offset="0.0"/>
                <GradientStop Color="Orange" Offset="0.17"/>
                <GradientStop Color="Yellow" Offset="0.33"/>
                <GradientStop Color="Green" Offset="0.5"/>
                <GradientStop Color="Blue" Offset="0.67"/>
                <GradientStop Color="Indigo" Offset="0.83"/>
                <GradientStop Color="Violet" Offset="1.0"/>
            </LinearGradientBrush>
        </TextBlock.Foreground>
        <TextBlock.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></TextBlock.RenderTransform>
    </TextBlock>

    <StackPanel Grid.Row="1" Padding="20">
        <ListView x:Name="lvNorthwind" Height="600">
            <ListView.Header>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                    <TextBlock Text="CustomerID" Width="120" FontWeight="Bold"/>
                    <TextBlock Text="CompanyName" Width="120" FontWeight="Bold"/>
                    <TextBlock Text="ContactName" Width="120" FontWeight="Bold"/>
                    <TextBlock Text="ContactTitle" Width="120" FontWeight="Bold"/>
                    <TextBlock Text="Address" Width="120" FontWeight="Bold"/>
                    <TextBlock Text="City" Width="120" FontWeight="Bold"/>
                    <TextBlock Text="PostalCode" Width="120" FontWeight="Bold"/>
                    <TextBlock Text="Country" Width="120" FontWeight="Bold"/>
                    <TextBlock Text="Phone" Width="120" FontWeight="Bold"/>
                </StackPanel>
            </ListView.Header>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="BorderBrush" Value="Gray"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="Padding" Value="16"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                        <TextBox Text="{Binding CustomerID}" IsReadOnly="True" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" Width="120"/>
                        <TextBox Text="{Binding CompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <TextBox Text="{Binding ContactName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <TextBox Text="{Binding ContactTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <TextBox Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <TextBox Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <TextBox Text="{Binding PostalCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <TextBox Text="{Binding Country, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <TextBox Text="{Binding Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                    </StackPanel>                    
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</Grid>
</Page>